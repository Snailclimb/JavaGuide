  <diagram name="07 Fallback 与幂等" id="fallback-idempotency">
    <mxGraphModel dx="1164" dy="629" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" background="#F8FAFC" math="0" shadow="0">
      <root>
        <mxCell id="p7-0" />
        <mxCell id="p7-1" parent="p7-0" />
        <mxCell id="p7-title" parent="p7-1" style="text;html=1;strokeColor=none;fillColor=none;fontColor=#2D3748;fontSize=24;fontStyle=1;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;" value="Fallback 不能只是换模型重试，必须和幂等、风险策略一起设计" vertex="1">
          <mxGeometry height="42" width="940" x="60" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p7-req" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0891B2;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="请求进入&lt;br&gt;requestId + idempotencyKey" vertex="1">
          <mxGeometry height="74" width="170" x="70" y="180" as="geometry" />
        </mxCell>
        <mxCell id="p7-cache" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CA497;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="幂等结果缓存&lt;br&gt;tenant + key" vertex="1">
          <mxGeometry height="74" width="160" x="325" y="180" as="geometry" />
        </mxCell>
        <mxCell id="p7-hit" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CA497;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="命中：直接返回历史 LLMResponse" vertex="1">
          <mxGeometry height="58" width="230" x="570" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p7-primary" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#005D7B;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontStyle=1;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="Primary Model&lt;br&gt;正常调用" vertex="1">
          <mxGeometry height="72" width="170" x="570" y="270" as="geometry" />
        </mxCell>
        <mxCell id="p7-error" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontSize=13;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="错误分类&lt;br&gt;网络 / 5xx / 429 / 参数 / 安全拒答" vertex="1">
          <mxGeometry height="74" width="190" x="805" y="270" as="geometry" />
        </mxCell>
        <mxCell id="p7-fallback" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="可 fallback&lt;br&gt;切备用同级模型" vertex="1">
          <mxGeometry height="68" width="170" x="805" y="405" as="geometry" />
        </mxCell>
        <mxCell id="p7-stop" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DC2626;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="不可 fallback&lt;br&gt;修请求 / 拒答 / 人工流程" vertex="1">
          <mxGeometry height="68" width="180" x="570" y="405" as="geometry" />
        </mxCell>
        <mxCell id="p7-save" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CA497;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="成功后保存结果&lt;br&gt;不是只存已处理标记" vertex="1">
          <mxGeometry height="72" width="190" x="325" y="530" as="geometry" />
        </mxCell>
        <mxCell id="p7-warn" parent="p7-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DC2626;strokeColor=none;fontColor=#FFFFFF;fontSize=14;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;shadow=1;" value="否则：主模型已生成但网关超时，fallback 再生成一次，报告落库两份、成本扣两遍。" vertex="1">
          <mxGeometry height="78" width="430" x="610" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p7-e1" edge="1" parent="p7-1" source="p7-req" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" target="p7-cache" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e2" edge="1" parent="p7-1" source="p7-cache" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4CA497;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#2D3748;labelBackgroundColor=#F8FAFC;" target="p7-hit" value="hit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e3" edge="1" parent="p7-1" source="p7-cache" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#2D3748;labelBackgroundColor=#F8FAFC;" target="p7-primary" value="miss">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e4" edge="1" parent="p7-1" source="p7-primary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#E99151;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#2D3748;labelBackgroundColor=#F8FAFC;" target="p7-error" value="异常">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e5" edge="1" parent="p7-1" source="p7-error" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#E99151;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#2D3748;labelBackgroundColor=#F8FAFC;" target="p7-fallback" value="可重试">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e6" edge="1" parent="p7-1" source="p7-error" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#DC2626;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#2D3748;labelBackgroundColor=#F8FAFC;" target="p7-stop" value="不可重试">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7-e7" edge="1" parent="p7-1" source="p7-primary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4CA497;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#2D3748;labelBackgroundColor=#F8FAFC;" target="p7-save" value="成功">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
